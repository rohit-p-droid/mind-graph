{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/ingest/route.ts": {
      "maxDuration": 300,
      "memory": 3008
    },
    "app/api/query/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/documents/route.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/api/delete/route.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "env": {
    "GEMINI_API_KEY": {
      "description": "Google Gemini API key for embeddings"
    },
    "GROQ_API_KEY": {
      "description": "Groq API key for LLM operations"
    },
    "NEO4J_URI": {
      "description": "Neo4j database connection URI (neo4j+s://)"
    },
    "NEO4J_USERNAME": {
      "description": "Neo4j database username"
    },
    "NEO4J_PASSWORD": {
      "description": "Neo4j database password"
    }
  }
}
