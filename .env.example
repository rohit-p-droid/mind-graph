GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Contact Information (displayed in the Contact Modal)
# Use NEXT_PUBLIC_ prefix to make these accessible in the browser
NEXT_PUBLIC_CONTACT_EMAIL=your-email@example.com
NEXT_PUBLIC_CONTACT_GITHUB=https://github.com/yourusername/mind-graph
NEXT_PUBLIC_CONTACT_PORTFOLIO=https://your-portfolio.com
NEXT_PUBLIC_CONTACT_LINKEDIN=https://linkedin.com/in/yourprofile
