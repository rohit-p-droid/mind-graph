{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "nodeVersion": "20.x",
  "functions": {
    "app/api/ingest/route.ts": {
      "maxDuration": 300,
      "memory": 3008
    },
    "app/api/query/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/documents/route.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/api/delete/route.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "env": [
    "GEMINI_API_KEY",
    "GROQ_API_KEY",
    "NEO4J_URI",
    "NEO4J_USERNAME",
    "NEO4J_PASSWORD"
  ]
}
