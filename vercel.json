{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/ingest/route.ts": {
      "maxDuration": 300,
      "memory": 2048
    },
    "app/api/query/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/documents/route.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/api/delete/route.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  }
}